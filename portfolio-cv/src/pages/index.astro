---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Hero from '../components/Hero';
import Skills from '../components/Skills';
import Projects from '../components/Projects';
import Trials from '../components/Trials';
import SavePoints from '../components/SavePoints';
---

<Layout title="ธรรมีนา | นักพัฒนา Full-Stack">
	<Navbar client:load />
	<main class="snap-container" id="main-scroll">
		<section id="hero"     class="snap-section"><Hero client:load /></section>
		<section id="skills"   class="snap-section"><Skills client:visible /></section>
		<section id="projects" class="snap-section"><Projects client:visible /></section>
		<section id="trials"   class="snap-section"><Trials client:visible /></section>
		<section id="about"    class="snap-section"><SavePoints client:visible /></section>
		<!-- Minimal footer inside the scroll container -->
		<footer class="flex items-center justify-center gap-2 py-5 text-xs"
			style="color:var(--fg-main);opacity:0.3;background:var(--bg-alt);">
			© 2025 ธรรมีนา &nbsp;·&nbsp; Start from Zero
		</footer>
	</main>
</Layout>
